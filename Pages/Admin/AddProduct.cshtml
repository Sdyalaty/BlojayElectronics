@page
@model AddProductModel
@{
    ViewData["Title"] = "Add Product";
}
<div class="container" style="max-width:600px;">
    <h1>Add Product</h1>
    <form method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Input.Description"></label>
            <textarea asp-for="Input.Description" class="form-control"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Price"></label>
            <input asp-for="Input.Price" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Input.CategoryId"></label>
            <select asp-for="Input.CategoryId" asp-items="Model.CategoryList" class="form-select"></select>
        </div>
        <div class="mb-3">
            <label asp-for="Input.ImageFile"></label>
            <input asp-for="Input.ImageFile" type="file" class="form-control" accept="image/*" />
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-page="/Admin/Products" class="btn btn-secondary">Cancel</a>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}