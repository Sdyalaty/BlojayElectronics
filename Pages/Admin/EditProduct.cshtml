@page
@model EditProductModel
@{
    ViewData["Title"] = "Edit Product";
}
<div class="container" style="max-width:600px;">
    <h1>Edit Product</h1>
    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Input.Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Input.Description"></label>
            <textarea asp-for="Input.Description" class="form-control"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Price"></label>
            <input asp-for="Input.Price" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Input.CategoryId"></label>
            <select asp-for="Input.CategoryId" asp-items="Model.CategoryList" class="form-select"></select>
        </div>
        <div class="mb-3">
            <label>Current Image</label><br />
            <img src="@Model.Input.ImageUrl" style="width:100px;" />
            <input type="hidden" asp-for="Input.ImageUrl" />
        </div>
        <div class="mb-3">
            <label asp-for="Input.ImageFile">Change Image (optional)</label>
            <input asp-for="Input.ImageFile" type="file" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-page="/Admin/Products" class="btn btn-secondary">Cancel</a>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}