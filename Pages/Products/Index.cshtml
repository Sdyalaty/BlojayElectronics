@page
@model BlojayElectronics.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Our Products";
}
<div class="container my-4">
    <h1 class="mb-4">Our Products</h1>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    <div class="row mb-4">
        <div class="col-md-3">
            <select id="categorySelect" class="form-select">
                <option value="0">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    if (Model.SelectedCategoryId == cat.Id)
                    {
                        <option value="@cat.Id" selected>@cat.Name</option>
                    }
                    else
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                }
            </select>
        </div>
    </div>
    <div class="row">
        @foreach (var product in Model.Products)
        {
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height:200px;object-fit:cover;">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-muted">@(product.Description.Length > 80 ? product.Description.Substring(0, 80) + "..." : product.Description)</p>
                        <p class="fw-bold text-primary">@product.Price.ToString("C")</p>
                        <form method="post" asp-page-handler="AddToCart" asp-route-id="@product.Id">
                            <input type="hidden" name="returnUrl" value="@Request.Path@Request.QueryString" />
                            <button type="submit" class="btn btn-outline-primary w-100"><i class="fas fa-cart-plus"></i> Add to Cart</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
    @if (!Model.Products.Any())
    {
        <div class="alert alert-info">No products found in this category.</div>
    }
</div>
@section Scripts {
    <script>
        document.getElementById('categorySelect').addEventListener('change', function () {
            window.location.href = '/Products/Index?selectedCategoryId=' + this.value;
        });
    </script>
}
