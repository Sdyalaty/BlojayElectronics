@page
@model PaymentModel
@{
    ViewData["Title"] = "Payment";
}

<div class="container my-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h2 class="mb-0">Payment</h2>
        </div>
        <div class="card-body">
            <h4>Order Summary</h4>
            <p><strong>Order #:</strong> @Model.Order?.Id</p>
            <p><strong>Total Amount:</strong> @Model.Order?.TotalAmount.ToString("C")</p>
            <p><strong>Payment Method:</strong> Mobile Money / Card (Simulated)</p>
            <hr />
            <form method="post">
                <button type="submit" class="btn btn-success btn-lg w-100">
                    <i class="fas fa-credit-card"></i> Pay Now (Simulate)
                </button>
            </form>
            <p class="text-muted mt-3">This is a simulation – no real money is charged.</p>
        </div>
    </div>
</div>