@page
@model CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}
<div class="container my-4">
    <h1>Checkout</h1>
    <div class="row">
        <div class="col-md-7">
            <div class="card">
                <div class="card-header bg-primary text-white">Billing Details</div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="mb-3">
                            <label asp-for="OrderInput.FullName"></label>
                            <input asp-for="OrderInput.FullName" class="form-control" />
                            <span asp-validation-for="OrderInput.FullName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="OrderInput.Email"></label>
                            <input asp-for="OrderInput.Email" class="form-control" />
                            <span asp-validation-for="OrderInput.Email" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="OrderInput.Phone"></label>
                            <input asp-for="OrderInput.Phone" class="form-control" />
                            <span asp-validation-for="OrderInput.Phone" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="OrderInput.Address"></label>
                            <textarea asp-for="OrderInput.Address" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="OrderInput.Address" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-success">Place Order</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card">
                <div class="card-header bg-secondary text-white">Your Order</div>
                <div class="card-body">
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="d-flex justify-content-between">
                            <span>@item.ProductName x @item.Quantity</span>
                            <span>@((item.Price * item.Quantity).ToString("C"))</span>
                        </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total:</span>
                        <span>@Model.Total.ToString("C")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}